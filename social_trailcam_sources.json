{
  "version": 1,
  "description": "Metadata-only social discovery sources for trail-camera creators, posts, videos, and public references.",
  "default_rules": {
    "collection_mode": "metadata_only",
    "download_media_by_default": false,
    "respect_robots_txt": true,
    "allow_logged_in_scraping": false,
    "allow_private_group_scraping": false,
    "allow_private_account_scraping": false,
    "allow_media_download": false,
    "request_timeout_seconds": 30,
    "max_results_per_query": 50,
    "user_agent": "camsleuth/0.1 social metadata discovery"
  },
  "sources": [
    {
      "source_id": "youtube_trailcam_discovery",
      "display_name": "YouTube Trail-Cam Discovery",
      "platform": "youtube",
      "source_type": "social_video_search",
      "base_url": "https://www.youtube.com/",
      "query_terms": ["trail camera", "trail cam", "game cam", "camera trap", "backyard wildlife camera", "trail cam deer", "trail cam bobcat", "trail cam coyote", "trail cam bear", "trail cam Pennsylvania", "Pennsylvania trail cam", "Berks County wildlife", "Oley wildlife"],
      "collection_mode": "metadata_only",
      "auth_mode": "public_web_or_official_api",
      "official_api": {
        "available": true,
        "name": "YouTube Data API",
        "credential_key": "youtube_data_api_key",
        "required_by_default": false
      },
      "allowed_outputs": ["video_url", "channel_url", "channel_name", "title", "description", "published_at", "hashtags", "species_terms", "broad_location", "view_count_if_available", "contact_path"],
      "media_download_default": false,
      "license_status": "unknown_contact_required",
      "permission_status": "not_requested",
      "priority": "high",
      "notes": "Best social discovery source for public trail-cam video creators and long-running channels."
